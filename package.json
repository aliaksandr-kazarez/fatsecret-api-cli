{
  "name": "fatsecret-api-client",
  "version": "1.0.0",
  "description": "FatSecret API client",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "start": "npm run build && node dist/server.js",
    "dev": "tsx --watch src/server.ts",
    "dev:client": "vite",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "clean": "rm -rf dist node_modules package-lock.json && npm install",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "lint:fix": "eslint src/**/*.ts src/**/*.tsx --fix"
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "crypto-js": "^4.1.1",
    "cookie-parser": "^1.4.6",
    "express-session": "^1.17.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.1.1",
    "@types/cookie-parser": "^1.4.6",
    "@types/express-session": "^1.17.10",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "eslint": "^9.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "fatsecret",
    "api",
    "client"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "glob": "^10.3.10",
    "rimraf": "^5.0.5"
  },
  "resolutions": {
    "glob": "^10.3.10",
    "rimraf": "^5.0.5"
  }
}
