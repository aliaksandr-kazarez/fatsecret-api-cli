{
  "name": "fatsecret-api-client",
  "version": "1.0.0",
  "description": "FatSecret API client",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "dev:log": "tsx --watch src/index.ts --log-file logs/app.log",
    "dev:debug": "tsx --watch src/index.ts --log-file logs/debug.log --debug",
    "dev:clean": "tsx --watch src/index.ts --no-logs",
    "live": "tsx --watch src/index.ts",
    "clean": "rm -rf dist node_modules package-lock.json && npm install",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "lint:fix": "eslint src/**/*.ts src/**/*.tsx --fix"
  },
  "dependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/inquirer": "^9.0.8",
    "axios": "^1.10.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.0",
    "ink": "^6.0.1",
    "inquirer": "^12.7.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.3",
    "@types/react": "^19.1.8",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "eslint": "^9.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "fatsecret",
    "api",
    "client"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "glob": "^10.3.10",
    "rimraf": "^5.0.5"
  },
  "resolutions": {
    "glob": "^10.3.10",
    "rimraf": "^5.0.5"
  }
}
